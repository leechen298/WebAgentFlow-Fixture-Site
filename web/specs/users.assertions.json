{
  "$schema_version": 1,
  "page_id": "users",
  "url_pattern": "/users",
  "description": "Validation-site user directory — list + search. Phase 9 scope covers only plain text input + Search. Popup-based controls (Cascader / pickers / Tag filter / column sort+filter) are on the page but not asserted on in this round — see specs/users.md §5.",

  "critical_elements": [
    {
      "role": "name_input",
      "expected_category": "fillable",
      "match_by": { "id": "search-name" }
    },
    {
      "role": "email_input",
      "expected_category": "fillable",
      "match_by": { "id": "search-email" }
    },
    {
      "role": "status_radio_active",
      "expected_category": "toggle",
      "expected_semantic_role": "status",
      "match_by": { "tag": "input", "element_type": "radio", "element_value": "active" }
    },
    {
      "role": "search_button",
      "expected_category": "submit",
      "match_by": { "id": "btn-search" }
    }
  ],

  "distractions": [
    {
      "role": "reset_button",
      "match_by": { "id": "btn-reset" }
    },
    {
      "role": "view_row_button",
      "match_by": { "tag": "button", "text_contains": "查看" }
    }
  ],

  "scenarios": {
    "filter_by_name": {
      "description": "Type 'alice' into the Name input, click Search. Table filters to the one matching row; URL gets ?name=alice.",
      "inputs": {
        "name": "alice"
      },
      "expected_actions": [
        "fill:name_input",
        "click:search_button"
      ],
      "success_signals": {
        "url_contains": "name=alice",
        "dom_contains_all_of": ["alice", "alice@example.com"]
      },
      "must_not_transition_to": null,
      "expected_verdict": "success"
    },

    "no_match": {
      "description": "Type a value that matches no user ('xyz999'), click Search. Table becomes empty; 'No users found' text shows; URL carries the filter but page stays at /users.",
      "inputs": {
        "name": "xyz999"
      },
      "expected_actions": [
        "fill:name_input",
        "click:search_button"
      ],
      "success_signals": {
        "url_contains": "name=xyz999",
        "dom_contains_all_of": ["未找到匹配的用户"]
      },
      "must_not_transition_to": "/login",
      "expected_verdict": "success"
    },

    "filter_by_status": {
      "description": "Pick the 'Active' radio in the Status group, click Search. Only active users remain; URL carries status=active. Drives the planner's native-toggle path (no text input involved).",
      "inputs": {},
      "selections": {
        "status": "active"
      },
      "expected_actions": [
        "click:status_radio_active",
        "click:search_button"
      ],
      "success_signals": {
        "url_contains": "status=active"
      },
      "must_not_transition_to": "/login",
      "expected_verdict": "success"
    }
  }
}
